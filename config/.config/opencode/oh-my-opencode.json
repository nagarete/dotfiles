{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "sisyphus_agent": {
    "default_builder_enabled": true
  },
  "agents": {
    "sisyphus": {
      "model": "opencode-go/deepseek-v4-pro",
      "ultrawork": { "model": "opencode-go/deepseek-v4-pro" },
      "fallback_models": [
        "opencode-go/deepseek-v4-pro",
        "opencode-go/minimax-m3"
      ]
    },
    "sisyphus-junior": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": [
        "opencode-go/minimax-m2.7",
        "opencode-go/minimax-m3"
      ]
    },
    "prometheus": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.7-plus"
      ]
    },
    "atlas": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/minimax-m3",
        "opencode-go/kimi-k2.6"
      ]
    },
    "hephaestus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.7-plus"
      ]
    },
    "metis": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/minimax-m3"
      ]
    },
    "explore": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/minimax-m3"
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m3",
      "fallback_models": [
        "opencode-go/deepseek-v4-flash",
        "opencode-go/minimax-m3",
        "opencode-go/minimax-m2.7"
      ]
    },
    "oracle": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.7-plus"
      ]
    },
    "momus": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/qwen3.7-plus"
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/mimo-v2-omni",
      "variant": "high",
      "fallback_models": [
        "opencode-go/kimi-k2.6",
        "opencode-go/kimi-k2.6"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": ["opencode-go/qwen3.7-plus", "opencode-go/mimo-v2-omni"]
    },
    "artistry": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": ["opencode-go/qwen3.7-plus", "opencode-go/mimo-v2-omni"]
    },
    "ultrabrain": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": ["opencode-go/qwen3.7-plus", "opencode-go/glm-5"]
    },
    "deep": {
      "model": "opencode-go/kimi-k2.6",
      "fallback_models": ["opencode-go/qwen3.7-plus", "opencode-go/kimi-k2.6"]
    },
    "quick": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": ["opencode-go/deepseek-v4-flash", "opencode-go/minimax-m3"]
    },
    "unspecified-low": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["opencode-go/minimax-m2.7", "opencode-go/minimax-m3"]
    },
    "unspecified-high": {
      "model": "opencode-go/deepseek-v4-pro",
      "fallback_models": ["opencode-go/qwen3.7-plus", "opencode-go/kimi-k2.6"]
    },
    "writing": {
      "model": "opencode-go/deepseek-v4-flash",
      "fallback_models": ["opencode-go/minimax-m2.7", "opencode-go/kimi-k2.6"]
    }
  },
  "background_task": {
    "providerConcurrency": {
      "opencode-go": 10
    },
    "modelConcurrency": {
      "opencode-go/minimax-m2.7": 20,
      "opencode-go/deepseek-v4-flash": 16,
      "opencode-go/kimi-k2.6": 14,
      "opencode-go/qwen3.7-plus": 12,
      "opencode-go/deepseek-v4-pro": 8,
      "opencode-go/minimax-m3": 10,
      "opencode-go/mimo-v2-omni": 4,
      "opencode-go/glm-5": 3,
      "opencode-go/mimo-v2-omni(high)": 2,
      "opencode-go/mimo-v2-omni(medium)": 3
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  }
}
