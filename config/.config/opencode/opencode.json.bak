{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "qwen3:8b": {
          "_launch": true,
          "name": "qwen3:8b"
        },
        "qwen3.5:9b": {
          "_launch": true,
          "name": "qwen3.5:9b"
        }
      },
      "name": "Ollama (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    },
    "ollama-cloud": {
      "models": {
        "kimi-k2.5": {
          "_launch": true,
          "name": "kimi-k2.5"
        },
        "minimax-m2.7": {
          "_launch": true,
          "name": "minimax-m2.7"
        }
      },
      "name": "Ollama Cloud",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.ollama.com/v1"
      }
    }
  },
  "plugin": [
    "oh-my-opencode@latest"
  ]
}
