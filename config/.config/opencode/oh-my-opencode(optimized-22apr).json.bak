{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
      "ultrawork": { "model": "opencode-go/kimi-k2.6" },
      "fallback_models": [
        "opencode-go/glm-5",
        "opencode-go/qwen3.6-plus"
      ]
    },
    "sisyphus-junior": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": [
        "opencode-go/minimax-m2.5",
        "opencode-go/minimax-m2.7"
      ]
    },
    "prometheus": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "opencode-go/qwen3.6-plus",
        "opencode-go/glm-5"
      ]
    },
    "atlas": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": [
        "opencode-go/minimax-m2.7",
        "opencode-go/kimi-k2.5"
      ]
    },
    "hephaestus": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": [
        "opencode-go/kimi-k2.5",
        "opencode-go/minimax-m2.7"
      ]
    },
    "metis": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": [
        "opencode-go/kimi-k2.5",
        "opencode-go/glm-5"
      ]
    },
    "explore": {
      "model": "opencode-go/minimax-m2.5",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        "opencode-go/minimax-m2.7"
      ]
    },
    "librarian": {
      "model": "opencode-go/minimax-m2.7",
      "fallback_models": [
        "opencode-go/qwen3.5-plus",
        "opencode-go/minimax-m2.5"
      ]
    },
    "oracle": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": [
        "opencode-go/kimi-k2.5",
        "opencode-go/glm-5"
      ]
    },
    "momus": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": [
        "opencode-go/kimi-k2.5",
        "opencode-go/glm-5"
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/mimo-v2-omni",
      "variant": "high",
      "fallback_models": [
        "opencode-go/kimi-k2.5",
        "opencode-go/qwen3.6-plus"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": ["opencode-go/kimi-k2.5", "opencode-go/mimo-v2-omni"]
    },
    "artistry": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": ["opencode-go/kimi-k2.5", "opencode-go/mimo-v2-omni"]
    },
    "ultrabrain": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": ["opencode-go/kimi-k2.6", "opencode-go/glm-5"]
    },
    "deep": {
      "model": "opencode-go/qwen3.6-plus",
      "fallback_models": ["opencode-go/kimi-k2.5", "opencode-go/minimax-m2.7"]
    },
    "quick": {
      "model": "opencode-go/minimax-m2.5",
      "fallback_models": ["opencode-go/qwen3.5-plus", "opencode-go/minimax-m2.7"]
    },
    "unspecified-low": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": ["opencode-go/minimax-m2.5", "opencode-go/minimax-m2.7"]
    },
    "unspecified-high": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": ["opencode-go/qwen3.6-plus", "opencode-go/glm-5"]
    },
    "writing": {
      "model": "opencode-go/qwen3.5-plus",
      "fallback_models": ["opencode-go/minimax-m2.5", "opencode-go/kimi-k2.5"]
    }
  },
  "background_task": {
    "providerConcurrency": {
      "opencode-go": 10
    },
    "modelConcurrency": {
      "opencode-go/minimax-m2.5": 20,
      "opencode-go/qwen3.5-plus": 18,
      "opencode-go/qwen3.6-plus": 14,
      "opencode-go/minimax-m2.7": 12,
      "opencode-go/kimi-k2.5": 8,
      "opencode-go/mimo-v2-omni": 4,
      "opencode-go/glm-5": 4,
      "opencode-go/kimi-k2.6": 3,
      "opencode-go/mimo-v2-omni(high)": 2,
      "opencode-go/mimo-v2-omni(medium)": 3
    }
  },
  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  }
}
